{
  "name": "elgibor-solution/laravel-form-builder",
  "description": "A Laravel package for managing form builder resources.",
  "type": "library",
  "license": "Apache-2.0",
  "autoload": {
    "psr-4": {
      "ESolution\\DataSources\\": "src/"
    }
  },
  "require": {
    "php": ">=8.2",
    "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "ESolution\\DataSources\\Providers\\DataSourcesServiceProvider"
      ]
    }
  }
}